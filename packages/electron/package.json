{
  "name": "@dgi/electron",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev":   "tsc && electron .",
    "build": "tsc",
    "dist":  "electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.1.0"
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.0",
    "typescript":       "^5.4.0",
    "@types/node":      "^20.11.0"
  },
  "build": {
    "appId":       "com.dgi.analyzer",
    "productName": "DGI Analyzer",
    "directories": {
      "output": "../../dist-electron"
    },
    "extraResources": [
      {
        "from":   "../../packages/backend/dist",
        "to":     "backend",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.finance"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}