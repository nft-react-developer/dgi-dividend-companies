{
  "ticker": "LOG",
  "sheets": {
    "income": {
      "sheetIndex": 0,
      "labelColumn": "A",
      "valueColumns": {
        "2018": "B",
        "2017": "C",
        "2016": "D"
      },
      "fields": {
        "revenue": {
          "type": "direct",
          "match": "Total Revenue",
          "aliases": ["Revenues", "Net Revenue", "Total Revenues"],
          "transform": "millions"
        },
        "costOfRevenue": {
          "type": "direct",
          "match": "Cost of Goods Sold",
          "aliases": ["Cost of Revenue", "COGS"],
          "transform": "millions"
        },
        "grossProfit": {
          "type": "direct",
          "match": "Gross Profit",
          "aliases": ["Gross Margin Total"],
          "transform": "millions"
        },
        "operatingIncome": {
          "type": "direct",
          "match": "Operating Income",
          "aliases": ["Income from Operations", "EBIT"],
          "transform": "millions"
        },
        "interestExpense": {
          "type": "direct",
          "match": "Interest Expense",
          "aliases": ["Interest Costs"],
          "transform": "millions",
          "negate": true
        },
        "pretaxIncome": {
          "type": "direct",
          "match": "Income Before Tax",
          "aliases": ["Pre-Tax Income", "Earnings Before Tax"],
          "transform": "millions"
        },
        "incomeTax": {
          "type": "direct",
          "match": "Income Tax Expense",
          "aliases": ["Provision for Income Taxes"],
          "transform": "millions"
        },
        "netIncome": {
          "type": "direct",
          "match": "Net Income",
          "aliases": ["Net Earnings", "Net Profit"],
          "transform": "millions"
        },
        "epsBasic": {
          "type": "direct",
          "match": "Basic EPS",
          "aliases": ["Earnings Per Share Basic", "EPS Basic"],
          "transform": "none"
        },
        "epsDiluted": {
          "type": "direct",
          "match": "Diluted EPS",
          "aliases": ["Earnings Per Share Diluted", "EPS Diluted"],
          "transform": "none"
        },
        "sharesBasic": {
          "type": "direct",
          "match": "Basic Shares Outstanding",
          "aliases": ["Shares Basic", "Weighted Average Shares Basic"],
          "transform": "millions"
        },
        "sharesDiluted": {
          "type": "direct",
          "match": "Diluted Shares Outstanding",
          "aliases": ["Shares Diluted", "Weighted Average Shares Diluted"],
          "transform": "millions"
        },
        "ebitda": {
          "type": "calc",
          "formula": "a + b + c",
          "vars": {
            "a": { "match": "Operating Income", "aliases": ["EBIT"], "transform": "millions" },
            "b": { "match": "Depreciation & Amortization", "aliases": ["D&A", "Depreciation and Amortization"], "transform": "millions" },
            "c": { "match": "Amortization of Intangibles", "aliases": ["Amortization"], "transform": "millions" }
          }
        },
        "netMarginPct": {
          "type": "calc",
          "formula": "a / b",
          "vars": {
            "a": { "match": "Net Income", "aliases": ["Net Earnings"], "transform": "millions" },
            "b": { "match": "Total Revenue", "aliases": ["Revenues"], "transform": "millions" }
          }
        }
      }
    },
