    "cashflow": {
      "sheetIndex": 2,
      "labelColumn": "A",
      "valueColumns": {
        "2018": "B",
        "2017": "C",
        "2016": "D"
      },
      "fields": {
        "operatingCashFlow": {
          "type": "direct",
          "match": "Cash from Operations",
          "aliases": ["Net Cash from Operating Activities", "Operating Cash Flow"],
          "transform": "millions"
        },
        "capex": {
          "type": "direct",
          "match": "Capital Expenditures",
          "aliases": ["Capex", "Purchase of Property Plant Equipment"],
          "transform": "millions",
          "negate": true
        },
        "freeCashFlow": {
          "type": "calc",
          "formula": "a - b",
          "vars": {
            "a": { "match": "Cash from Operations", "aliases": ["Operating Cash Flow"], "transform": "millions" },
            "b": { "match": "Capital Expenditures", "aliases": ["Capex"], "transform": "millions", "negate": true }
          }
        },
        "dividendsPaid": {
          "type": "direct",
          "match": "Dividends Paid",
          "aliases": ["Common Dividends", "Cash Dividends Paid"],
          "transform": "millions",
          "negate": true
        },
        "payoutRatio": {
          "type": "calc",
          "formula": "abs(a) / b",
          "vars": {
            "a": { "match": "Dividends Paid", "aliases": ["Common Dividends"], "transform": "millions" },
            "b": { "match": "Net Income", "aliases": ["Net Earnings"], "transform": "millions" }
          }
        }
